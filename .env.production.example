DEPLOY_ENV_FILE=.env.production
APP_MODE=test
PORT=8080
DATABASE_URL=postgres://casino:change-me-db-password@postgres:5432/casino
REDIS_URL=redis://redis:6379
JWT_SECRET=change-me-jwt-secret
